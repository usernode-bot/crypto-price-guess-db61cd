{
  "secrets": [
    {
      "key": "APP_PUBKEY",
      "description": "Usernode blockchain address that receives 1-token guess payments (server-side debit destination)",
      "required": false,
      "private": false,
      "default": ""
    },
    {
      "key": "APP_PRIVKEY",
      "description": "Private key for APP_PUBKEY — signs payout and result-memo transactions",
      "required": false,
      "private": true,
      "staging_default": "staging_dummy_privkey_not_real"
    },
    {
      "key": "ADMIN_KEY",
      "description": "Secret for /api/admin/daily-results endpoint (x-admin-key header)",
      "required": false,
      "private": false
    },
    {
      "key": "COINGECKO_API_KEY",
      "description": "Optional CoinGecko API key for higher rate limits (x-cg-demo-api-key header)",
      "required": false,
      "private": false,
      "default": ""
    }
  ],
  "tests": [
    {
      "name": "Dashboard loads with countdown timer",
      "path": "/",
      "expectSelector": ".countdown-timer"
    },
    {
      "name": "Guess screen renders asset selector cards",
      "path": "/#guess",
      "expectSelector": ".asset-card"
    },
    {
      "name": "Guess screen renders 1-hour preview chart",
      "path": "/#guess",
      "expectSelector": ".guess-chart"
    },
    {
      "name": "History screen renders round list",
      "path": "/#history",
      "expectSelector": ".history-round"
    },
    {
      "name": "Top Guessers leaderboard renders player rows",
      "path": "/#leaderboard",
      "expectSelector": ".leaderboard-row",
      "expectText": "Top Guessers"
    },
    {
      "name": "My Predictions tab renders prediction cards",
      "path": "/?demo=1#history",
      "expectSelector": ".prediction-row"
    }
  ]
}
